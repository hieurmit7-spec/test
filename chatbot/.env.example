# Environment Variables for NVIDIA NIM & Supabase

VITE_NVIDIA_NIM_API_KEY=your_nim_api_key_here
VITE_NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
VITE_NVIDIA_NIM_MODEL=meta/llama3-70b-instruct

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Build-time variables for Cloudflare Pages (Optional)
NODE_VERSION=20
